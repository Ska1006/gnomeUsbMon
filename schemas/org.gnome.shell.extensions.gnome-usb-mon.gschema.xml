<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
  <enum id="org.gnome.shell.extensions.gnome-usb-mon.panel-mode">
    <value nick="icon-only" value="0"/>
    <value nick="icon-watts" value="1"/>
    <value nick="icon-watts-percent" value="2"/>
  </enum>
  <enum id="org.gnome.shell.extensions.gnome-usb-mon.usb-list-mode">
    <value nick="off" value="0"/>
    <value nick="basic" value="1"/>
  </enum>
  <enum id="org.gnome.shell.extensions.gnome-usb-mon.usb-list-scope">
    <value nick="external" value="0"/>
    <value nick="all" value="1"/>
  </enum>

  <schema id="org.gnome.shell.extensions.gnome-usb-mon"
          path="/org/gnome/shell/extensions/gnome-usb-mon/">
    <key name="panel-mode" enum="org.gnome.shell.extensions.gnome-usb-mon.panel-mode">
      <default>'icon-watts'</default>
      <summary>Panel display mode</summary>
      <description>What the top-bar indicator shows.</description>
    </key>
    <key name="hide-when-idle" type="b">
      <default>true</default>
      <summary>Hide indicator when no external devices</summary>
    </key>
    <key name="hide-ignore-list" type="as">
      <default>[]</default>
      <summary>Devices ignored for idle-hide</summary>
      <description>VID:PID or class strings NOT counted as external.</description>
    </key>
    <key name="poll-interval" type="i">
      <range min="1" max="10"/>
      <default>2</default>
      <summary>Live poll interval (seconds)</summary>
    </key>
    <key name="usb-list-mode" enum="org.gnome.shell.extensions.gnome-usb-mon.usb-list-mode">
      <default>'basic'</default>
      <summary>USB device list in menu</summary>
    </key>
    <key name="usb-list-scope" enum="org.gnome.shell.extensions.gnome-usb-mon.usb-list-scope">
      <default>'external'</default>
      <summary>Which USB devices to list</summary>
      <description>external = только removable-порты; all = включая встроенные.</description>
    </key>
    <key name="notify-charger" type="b">
      <default>true</default>
      <summary>Notify on charger plug/unplug</summary>
    </key>
    <key name="notify-usb" type="b">
      <default>false</default>
      <summary>Notify on USB device plug/unplug</summary>
    </key>
    <key name="show-pdo-list" type="b">
      <default>true</default>
      <summary>Show charger PDO profiles submenu</summary>
    </key>
  </schema>
</schemalist>
